-- 2. NUMBER AT PARSING FUNCTIONS
local suffixes = {"K", "M", "B", "T", "QA", "QI"}
local function formatNumber(value)
    if not value or typeof(value) ~= "number" then return "0" end
    if value < 1000 then return tostring(value) end
    
    local index = math.floor(math.log10(value) / 3)
    local suffix = suffixes[index] or ""
    local abbreviated = value / (10 ^ (index * 3))
    
    return string.format("%.1f", abbreviated):gsub("%.0$", "") .. suffix
end

local function cleanAndParseNumber(val)
    if typeof(val) == "number" then return val end
    if typeof(val) == "boolean" then return val and 1 or 0 end
    if typeof(val) ~= "string" then return 0 end
    
    local cleanStr = string.upper(string.gsub(val, "[%s,]", ""))
    local numPart = tonumber(string.match(cleanStr, "^[%d%.%-]+")) or 0
    local textPart = string.match(cleanStr, "[A-Z]+$") or ""
    local multipliers = {K = 10^3, M = 10^6, B = 10^9, T = 10^12}
    if multipliers[textPart] then return numPart * multipliers[textPart] end
    return numPart
end

-- 3. INTERFACE RESET FUNCTION
local function resetSpyTracking()
    targetBaselineStats = {}
    for _, name in ipairs(TargetStatNames) do
        if Spy_UI_Labels[name] then
            Spy_UI_Labels[name].Text = name .. ": N/A"
        end
    end
end

-- 4. SMART STAT SCANNER FUNCTION
local function getRemotePlayerStat(plr, statName)
    if not plr or not plr.Parent then return nil end
    local cleanTarget = string.lower(statName)
    
    local aliases = {
        ["coins"] = {"coins", "coin", "cash", "money", "gold"},
        ["strength"] = {"strength", "str", "power", "biceps"},
        ["gems"] = {"gems", "gem", "diamonds", "diamond"},
        ["prestige"] = {"prestige", "rebirth", "rebirths", "tier"},
        ["kos"] = {"kos", "ko", "kills", "wipeouts"}
    }
    
    local keywords = aliases[cleanTarget] or {cleanTarget}
    
    -- Check leaderstats / Folders
    local commonFolders = {"leaderstats", "Stats", "Data", "leaderstats2"}
    for _, fName in ipairs(commonFolders) do
        local folder = plr:FindFirstChild(fName)
        if folder then
            for _, child in ipairs(folder:GetChildren()) do
                local cName = string.lower(child.Name)
                for _, word in ipairs(keywords) do
                    if cName == word or string.find(cName, word) then
                        if child:IsA("ValueBase") or child.ClassName:find("Value") then
                            return cleanAndParseNumber(child.Value)
                        end
                    end
                end
            end
        end
    end
    
    -- Check Attributes
    for attrName, attrValue in pairs(plr:GetAttributes()) do
        local cAttr = string.lower(attrName)
        for _, word in ipairs(keywords) do
            if cAttr == word or string.find(cAttr, word) then
                return cleanAndParseNumber(attrValue)
            end
        end
    end
    
    return nil
end

