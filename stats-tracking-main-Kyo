local trackedAttributes = {} -- Map to track custom player attributes
local startTime = os.time() 

-- Number Abbreviation Engine (1000 -> 1K)
local suffixes = {"K", "M", "B", "T", "QA", "QI"}
local function formatNumber(value)
    if not value or typeof(value) ~= "number" then return "0" end
    if value < 1000 then return tostring(value) end
    
    local index = math.floor(math.log10(value) / 3)
    local suffix = suffixes[index] or ""
    local abbreviated = value / (10 ^ (index * 3))
    
    return string.format("%.1f", abbreviated):gsub("%.0$", "") .. suffix
end

-- Helper: Unpacks text data like "50K" or "100 Gems" into a math-ready number
local function cleanAndParseNumber(val)
    if typeof(val) == "number" then return val end
    if typeof(val) == "boolean" then return val and 1 or 0 end
    if typeof(val) ~= "string" then return 0 end
    
    local cleanStr = string.upper(string.gsub(val, "[%s,]", ""))
    local numPart = tonumber(string.match(cleanStr, "^[%d%.%-]+")) or 0
    local textPart = string.match(cleanStr, "[A-Z]+$") or ""
    local multipliers = {K = 10^3, M = 10^6, B = 10^9, T = 10^12}
    if multipliers[textPart] then return numPart * multipliers[textPart] end
    return numPart
end

-- Register a discovered stat to the UI system
local function registerNewDiscoveredStat(displayName, sourceObj, isAttribute)
    if My_UI_Labels[displayName] then return end -- Skip if already setup
    
    -- Exclude messy or useless system names that aren't real gameplay stats
    local blacklistedNames = {["playergui"] = true, ["backpack"] = true, ["character"] = true, ["name"] = true, ["userid"] = true}
    if blacklistedNames[string.lower(displayName)] then return end
    
    -- Dynamically add label to your tab
    My_UI_Labels[displayName] = TrackerTab:AddLabel(displayName .. ": Loading...")
    
    -- Initialize starting values
    local initialValue = 0
    if isAttribute then
        trackedAttributes[displayName] = true
        initialValue = cleanAndParseNumber(LocalPlayer:GetAttribute(displayName))
    else
        trackedObjects[displayName] = sourceObj
        initialValue = cleanAndParseNumber(sourceObj.Value)
    end
    
    startingStats[displayName] = initialValue
end

-- Master Game Scan: Dives deep into every nook and cranny of the Player instance
local function runGameWideStatScan()
    -- 1. Grab everything on the main leaderboard folder first
    local leaderstatsFolder = LocalPlayer:FindFirstChild("leaderstats")
    if leaderstatsFolder then
        for _, child in ipairs(leaderstatsFolder:GetChildren()) do
            if child:IsA("ValueBase") or child.ClassName:find("Value") then
                registerNewDiscoveredStat("[Leaderboard] " .. child.Name, child, false)
            end
        end
    end
    
    -- 2. Scan modern Player Attributes (Used heavily by newer simulators)
    for attrName, attrValue in pairs(LocalPlayer:GetAttributes()) do
        if typeof(attrValue) == "number" or tonumber(string.match(tostring(attrValue), "^[%d%.]+")) then
            registerNewDiscoveredStat("[Attribute] " .. attrName, nil, true)
        end
    end
    
    -- 3. Run a deep search across ALL sub-folders (Data, Stats, Profiles, Settings, etc.)
    for _, descendant in ipairs(LocalPlayer:GetDescendants()) do
        if descendant:IsA("ValueBase") or descendant.ClassName:find("Value") then
            -- Make sure we don't accidentally re-add what we found in leaderstats with a generic tag
            if not descendant:IsDescendantOf(leaderstatsFolder) then
                registerNewDiscoveredStat("[Deep Scan] " .. descendant.Name, descendant, false)
            end
        end
    end
end

-- Asynchronous Visual Update Loop
task.spawn(function()
    while task.wait(0.2) do
        local elapsedSeconds = math.max(os.time() - startTime, 1) 
        
        -- Continuously scan the game files for late-loading stats
        runGameWideStatScan()
        
        -- Process math formulas and update text displays
        for displayName, uiElement in pairs(My_UI_Labels) do
            local currentVal = 0
            local isValid = false
            
            if trackedAttributes[displayName] then
                -- Strip prefix out to read actual raw attribute key
                local rawName = string.gsub(displayName, "^%[.-%]%s*", "")
                currentVal = cleanAndParseNumber(LocalPlayer:GetAttribute(rawName))
                isValid = true
            else
                local obj = trackedObjects[displayName]
                if obj and obj.Parent then
                    currentVal = cleanAndParseNumber(obj.Value)
                    isValid = true
                end
            end
            
            if isValid then
                local startVal = startingStats[displayName] or currentVal
                
                -- Catch zero boundaries if values loaded slowly
                if startVal == 0 and startingStats[displayName] == 0 then
                    startingStats[displayName] = currentVal
                    startVal = currentVal
                end
                
                local gained = currentVal - startVal
                local formattedCurrent = formatNumber(currentVal)
                
                if gained > 0 then
                    local perSecond = gained / elapsedSeconds
                    local perMinute = perSecond * 60
                    local perHour = perSecond * 3600
                    local perDay = perSecond * 86400
                    local perWeek = perSecond * 604800
                    
                    uiElement.Text = string.format(
                        "%s: %s (+%s) | /m: %s | /h: %s | /d: %s | /w: %s",
                        displayName, 
                        formattedCurrent, 
                        formatNumber(gained),
                        formatNumber(perMinute),
                        formatNumber(perHour),
                        formatNumber(perDay),
                        formatNumber(perWeek)
                    )
                else
                    uiElement.Text = displayName .. ": " .. formattedCurrent .. " (+0) | /m: 0 | /h: 0 | /d: 0 | /w: 0"
                end
            else
                uiElement.Text = displayName .. ": Out of Range"
            end
        end
    end
end)

